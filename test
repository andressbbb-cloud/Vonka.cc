-- Auto-tooltips for EVERY toggle in this example:
-- If you didn't specify Tooltip, it will default to the toggle Name.
do
    local oldToggle = Library and Library.Sections and Library.Sections.Toggle
    if type(oldToggle) == "function" then
        Library.Sections.Toggle = function(self, Data)
            Data = Data or {}
            Data.Tooltip = Data.Tooltip or Data.tooltip or Data.Description or Data.description or Data.Tip or Data.tip or Data.Name or Data.name
            return oldToggle(self, Data)
        end
    end
end

