local Flags = Library.Flags

-- Helper to read flag values safely
local function F(flag)
    local v = (Flags and Flags[flag])
    if v == nil then return false end
    if type(v) == "table" then
        local res = v.Color or v.Key or v.Toggled
        if res ~= nil then return res end
        return v
    end
    return v
end

local DrawingLib = type(Drawing) == "table" and Drawing or nil

local function makeDrawing(kind)
    if DrawingLib and type(DrawingLib.new) == "function" then
        local ok, obj = pcall(DrawingLib.new, kind)
        if ok and obj then
            return obj
        end
    end

    return setmetatable({
        Visible = false,
        Remove = function() end,
        Destroy = function() end,
    }, {
        __index = function(t, k)
            return rawget(t, k)
        end,
        __newindex = function(t, k, v)
            rawset(t, k, v)
        end,
    })
end

-- Checks if a feature should be active based on its toggle and optional keybind
local function active(toggleFlag, keyFlag)
    if not F(toggleFlag) then return false end
    if not keyFlag then return true end
    
    local flagVal = Flags[keyFlag]
    if not flagVal or type(flagVal) ~= "table" then return true end
    
    local keyStr = flagVal.Key
    if not keyStr or keyStr == "" then return true end
    
    local keyName = tostring(keyStr):match("KeyCode%.(.+)$")
    if not keyName or keyName == "Unknown" then return true end
    
    local mode = flagVal.Mode or "Toggle"
    if mode == "Toggle" then
        return flagVal.Toggled == true
    else
        -- Hold mode: check IsKeyDown
        local ok, kc = pcall(function() return Enum.KeyCode[keyName] end)
        if not ok or not kc then return true end
        return game:GetService("UserInputService"):IsKeyDown(kc)
    end
end

