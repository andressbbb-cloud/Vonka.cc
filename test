do -- Movement + Misc logic
    local Players   = game:GetService("Players")
    local RS        = game:GetService("RunService")
    local UIS       = game:GetService("UserInputService")
    local LP        = Players.LocalPlayer

    local char, hrp, hum, noclipParts = nil, nil, nil, {}
    
    -- Caches the local player's character and humanoid parts for quick access
    local function cacheNoclipParts(targetChar)
        table.clear(noclipParts)
        if not targetChar then return end
        for _, p in ipairs(targetChar:GetDescendants()) do
            if p:IsA("BasePart") then
                noclipParts[#noclipParts + 1] = p
            end
        end
    end

    local function refreshChar()
        char = LP.Character
        if not char then return end
        hrp  = char:FindFirstChild("HumanoidRootPart") or char:WaitForChild("HumanoidRootPart", 5)
        hum  = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 5)
        cacheNoclipParts(char)
    end
    refreshChar()
    
    LP.CharacterAdded:Connect(function(c)
        char = c
        task.wait(0.1)
        hrp  = c:FindFirstChild("HumanoidRootPart")
        hum  = c:FindFirstChildOfClass("Humanoid")
        cacheNoclipParts(c)

        c.DescendantAdded:Connect(function(d)
            if d:IsA("BasePart") then
                noclipParts[#noclipParts + 1] = d
            end
        end)
        c.DescendantRemoving:Connect(function(d)
            if d:IsA("BasePart") then
                for i = #noclipParts, 1, -1 do
                    if noclipParts[i] == d then
                        table.remove(noclipParts, i)
                        break
                    end
                end
            end
        end)
        
        -- Re-apply anti-trip/sit on respawn
        if F("Move Anti Trip") and hum then 
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false) 
        end
        if F("Move Anti Sit") and hum then 
            hum:SetStateEnabled(Enum.HumanoidStateType.Seated, false) 
        end
    end)

    -- ── SPEED ────────────────────────────────────────────────────────────────
    local slipperyVel = Vector3.new(0, 0, 0)
    
    RS.Heartbeat:Connect(function(dt)
        if not active("Move Speed", "Move Speed Key") then 
            slipperyVel = Vector3.new(0, 0, 0)
            return 
        end
        if not hrp or not hum then return end
        
        local spd     = (F("Move Speed Value") or 35) * 16
        local style   = F("Move Speed Style") or "Normal"
        local dir     = hum.MoveDirection
        
        local w = UIS:IsKeyDown(Enum.KeyCode.W)
        local s = UIS:IsKeyDown(Enum.KeyCode.S)
        local a = UIS:IsKeyDown(Enum.KeyCode.A)
        local d = UIS:IsKeyDown(Enum.KeyCode.D)
        local moving = w or s or a or d

        if style == "Normal" then
            -- Standard linear speed increase
            hrp.CFrame += Vector3.new(dir.X, 0, dir.Z) * dt * spd
            
        elseif style == "Bhop" then
            -- Speed increase + automatic jumping when moving
            hrp.CFrame += Vector3.new(dir.X, 0, dir.Z) * dt * spd
            if hum:GetState() == Enum.HumanoidStateType.Running and moving then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
            
        elseif style == "Minecraft" then
            -- Quick hop simulation
            hrp.CFrame += Vector3.new(dir.X, 0, dir.Z) * dt * spd
            if hum:GetState() == Enum.HumanoidStateType.Running and moving then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
                hrp.Velocity *= Vector3.new(1, 1.5, 1)
                task.wait(hum.JumpPower / 500)
                hrp.Velocity *= Vector3.new(1, -1.1, 1)
            end
            
        elseif style == "Slippery" then
            -- Ice-skating like momentum
            local old = hrp.Velocity
            local grounded = hum:GetState() == Enum.HumanoidStateType.Running
            if dir.Magnitude > 0 and grounded then
                slipperyVel = slipperyVel:Lerp(dir * dt * spd * 150, 0.35) * (1 + dt)
            elseif not grounded then
                slipperyVel *= (1 - (dt * 4))
            end
            hrp.Velocity = Vector3.new(slipperyVel.X, old.Y, slipperyVel.Z)
        end
    end)

    -- ── FLIGHT ───────────────────────────────────────────────────────────────
    local floatVel = Vector3.new(0, math.pi - 2, 0)
    
    RS.Heartbeat:Connect(function(dt)
        if not active("Move Flight", "Move Flight Key") then return end
        if not hrp or not hum then return end
        
        local spd = (F("Move Flight Speed") or 35) * 50
        local dir = hum.MoveDirection
        local cam = workspace.CurrentCamera
        
        -- Calculate vertical movement based on camera look vector and key presses
        local upDown = UIS:IsKeyDown(Enum.KeyCode.Space) and 1
            or (UIS:IsKeyDown(Enum.KeyCode.S) and -cam.CFrame.LookVector.Y
            or  UIS:IsKeyDown(Enum.KeyCode.W) and  cam.CFrame.LookVector.Y or 0)
                * math.clamp(dir.Magnitude, 0, 1)
                
        hrp.Velocity = floatVel
        hrp.CFrame += Vector3.new(dir.X, upDown, dir.Z) * dt * spd
    end)

    -- ── NOCLIP ───────────────────────────────────────────────────────────────
    RS.Stepped:Connect(function()
        if not F("Move Noclip") then return end
