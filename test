            end
        end
        
        for _, d in ipairs({obj.trOut, obj.tr, obj.nm, obj.dn, obj.dist, obj.tool, obj.hpBG, obj.hpBar, obj.hpTxt, obj.boxFill}) do
            d.Visible = false
        end
    end

    -- Calculates 2D bounding box from cached 3D parts
    -- Optimized by avoiding GetDescendants per frame
    local function getBounds(parts)
        local x0, y0, x1, y1 = math.huge, math.huge, -math.huge, -math.huge
        local tz, n = 0, 0
        
        for _, p in ipairs(parts) do
            if p and p.Parent then
                local hx, hy, hz = p.Size.X / 2, p.Size.Y / 2, p.Size.Z / 2
                local cf = p.CFrame
                local corners = {
                    Vector3.new(hx, hy, hz),  Vector3.new(-hx, hy, hz),
                    Vector3.new(hx, -hy, hz), Vector3.new(-hx, -hy, hz),
                    Vector3.new(hx, hy, -hz), Vector3.new(-hx, hy, -hz),
                    Vector3.new(hx, -hy, -hz), Vector3.new(-hx, -hy, -hz),
                }
                
                for _, o in ipairs(corners) do
                    local sp = Cam:WorldToViewportPoint((cf * CFrame.new(o)).Position)
                    if sp.Z > 0 then
                        if sp.X < x0 then x0 = sp.X end
                        if sp.Y < y0 then y0 = sp.Y end
                        if sp.X > x1 then x1 = sp.X end
                        if sp.Y > y1 then y1 = sp.Y end
                        tz = tz + sp.Z
                        n = n + 1
                    end
                end
            end
        end
        
        if n == 0 then return nil end
        return x0, y0, x1, y1, tz / n
    end



    -- Safely converts 3D position to 2D screen space
