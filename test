-- Real-time Ping and FPS tracking for Watermark
task.spawn(function()
    local RS = game:GetService("RunService")
    local Stats = game:GetService("Stats")
    
    local gameName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name
    local frames = 0
    local lastTime = tick()
    
    RS.RenderStepped:Connect(function()
        frames = frames + 1
        local now = tick()
        
        if now - lastTime >= 1 then
            local fps = frames
            frames = 0
            lastTime = now
            
            local ping = 0
            
            -- Method 1: PerformanceStats (Works on 99% of executors natively)
            local success = pcall(function()
                ping = math.floor(Stats.PerformanceStats.Ping:GetValue())
            end)
            
            -- Method 2: Network Server Stats (Fallback)
            if not success or ping == 0 then
                pcall(function()
                    ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
                end)
            end
            
            -- Hard update the UI label
            if Watermark and Watermark.SetText then
                Watermark:SetText(string.format("Vonka.cc / %d ms / %d fps / %s", ping, fps, gameName))
            end
        end
    end)
end)
