do
    local lp = game:GetService("Players").LocalPlayer
    local gui = lp:WaitForChild("PlayerGui")
    local Lighting = game:GetService("Lighting")
    local TweenService = game:GetService("TweenService")

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "VonkaCinematicIntro"
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.ResetOnSpawn = false
    ScreenGui.Parent = gui

    -- Cinematic Lighting Effects
    local Blur = Instance.new("BlurEffect")
    Blur.Size = 0
    Blur.Parent = Lighting

    local CC = Instance.new("ColorCorrectionEffect")
    CC.TintColor = Color3.fromRGB(255, 255, 255)
    CC.Contrast = 0
    CC.Saturation = 0
    CC.Parent = Lighting

    -- Background (starts transparent, fades in)
    local BG = Instance.new("Frame")
    BG.Size = UDim2.fromScale(1, 1)
    BG.BackgroundColor3 = Color3.fromRGB(5, 5, 5)
    BG.BackgroundTransparency = 1
    BG.BorderSizePixel = 0
    BG.Parent = ScreenGui

    -- Vignette (darkened edges, starts invisible)
    local Vignette = Instance.new("ImageLabel")
    Vignette.Size = UDim2.fromScale(1, 1)
    Vignette.BackgroundTransparency = 1
    Vignette.Image = "rbxassetid://13501258169"
    Vignette.ImageColor3 = Color3.fromRGB(0, 0, 0)
    Vignette.ImageTransparency = 1
    Vignette.Parent = BG

    -- Grid / Particles (starts invisible)
    local Grid = Instance.new("ImageLabel")
    Grid.Size = UDim2.fromScale(1, 1)
    Grid.BackgroundTransparency = 1
    Grid.Image = "rbxassetid://43033504"
    Grid.ImageTransparency = 1
    Grid.ImageColor3 = Color3.fromRGB(255, 20, 50)
    Grid.ScaleType = Enum.ScaleType.Tile
    Grid.TileSize = UDim2.fromOffset(256, 256)
    Grid.Parent = BG

    -- Logo (starts invisible and slightly smaller)
    local Logo = Instance.new("ImageLabel")
    Logo.Size = UDim2.fromOffset(200, 200)
    Logo.Position = UDim2.fromScale(0.5, 0.5)
    Logo.AnchorPoint = Vector2.new(0.5, 0.5)
    Logo.BackgroundTransparency = 1
    Logo.Image = "rbxassetid://75743174422975"
    Logo.ImageTransparency = 1
    Logo.ScaleType = Enum.ScaleType.Fit
    Logo.Rotation = -5
    Logo.Parent = BG

    -- Cinematic Sounds
    local YeatSound = Instance.new("Sound")
    YeatSound.SoundId = "rbxassetid://122018002470606"
    YeatSound.Volume = 1.5
    YeatSound.Parent = game:GetService("SoundService")

    if not YeatSound.IsLoaded then YeatSound.Loaded:Wait() end
    YeatSound:Play()

    -- === PHASE 1: Fade In (0.6s) ===
    local fadeInInfo = TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

    TweenService:Create(BG, fadeInInfo, {BackgroundTransparency = 0}):Play()
    TweenService:Create(Vignette, fadeInInfo, {ImageTransparency = 0.2}):Play()
    TweenService:Create(Grid, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {ImageTransparency = 0.8}):Play()
    TweenService:Create(Blur, fadeInInfo, {Size = 24}):Play()
    TweenService:Create(CC, fadeInInfo, {Contrast = 0.2, Saturation = -0.5}):Play()

    task.wait(0.3)

    -- === PHASE 2: Logo Reveal (0.8s) ===
    local logoRevealInfo = TweenInfo.new(0.8, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    TweenService:Create(Logo, logoRevealInfo, {
        ImageTransparency = 0,
        Size = UDim2.fromOffset(300, 300),
        Rotation = 0
    }):Play()

    -- Wait for the sound duration
    task.wait(2.2)

    -- === PHASE 3: Fade Out (0.8s) ===
    local fadeOutInfo = TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

    TweenService:Create(Logo, fadeOutInfo, {
        ImageTransparency = 1,
        Size = UDim2.fromOffset(500, 500),
        Rotation = 10
    }):Play()

    task.wait(0.3)

    local bgFadeInfo = TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)

    TweenService:Create(Grid, bgFadeInfo, {ImageTransparency = 1}):Play()
    TweenService:Create(Vignette, bgFadeInfo, {ImageTransparency = 1}):Play()
    TweenService:Create(BG, bgFadeInfo, {BackgroundTransparency = 1}):Play()

    -- Restore Lighting
    TweenService:Create(Blur, bgFadeInfo, {Size = 0}):Play()
    TweenService:Create(CC, bgFadeInfo, {Contrast = 0, Saturation = 0}):Play()

    task.wait(0.8)

    YeatSound:Destroy()
    Blur:Destroy()
    CC:Destroy()
    ScreenGui:Destroy()
end

