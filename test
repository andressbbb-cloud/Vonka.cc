    local function cleanupGodMode()
        if godTrack then pcall(function() godTrack:Stop(); godTrack:Destroy() end); godTrack = nil end
        if godHeartbeat then godHeartbeat:Disconnect(); godHeartbeat = nil end
        if godAnimConn then godAnimConn:Disconnect(); godAnimConn = nil end
    end

    local function startGodMode()
        if not hum then return end
        cleanupGodMode()

        local anim = Instance.new("Animation")
        anim.AnimationId = godEmoteId
        
        local ok, track = pcall(function() return hum:LoadAnimation(anim) end)
        if not ok or not track then return end
        
        godTrack = track
        godTrack:Play(0, 1, 1)

        godHeartbeat = RS.Heartbeat:Connect(function()
            if godTrack and godActive then
                local freezePos = F("Misc God Mode Freeze Time")
                godTrack.TimePosition = (type(freezePos) == "number" and freezePos or 0.1265)
                godTrack:AdjustSpeed(0)
            end
        end)

        godAnimConn = hum.AnimationPlayed:Connect(function(newtrack)
            if godActive and godTrack and newtrack ~= godTrack then
                task.delay(0.02 + math.random() * 0.03, function()
                    if godActive then startGodMode() end
                end)
            end
        end)
    end

    RS.Heartbeat:Connect(function()
        local isEnabled = active("Misc God Mode", "Misc God Mode Key")
        if isEnabled ~= godActive then
            godActive = isEnabled
            if godActive then
                startGodMode()
            else
                cleanupGodMode()
            end
        end
    end)

    LP.CharacterAdded:Connect(function(c)
        task.wait(0.25)
        if godActive then startGodMode() end
    end)
end

