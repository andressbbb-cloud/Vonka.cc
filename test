                            {Vector2.new(x1, y0), Vector2.new(x1 - corner, y0)},
                            {Vector2.new(x1, y0), Vector2.new(x1, y0 + corner)},
                            {Vector2.new(x0, y1), Vector2.new(x0 + corner, y1)},
                            {Vector2.new(x0, y1), Vector2.new(x0, y1 - corner)},
                            {Vector2.new(x1, y1), Vector2.new(x1 - corner, y1)},
