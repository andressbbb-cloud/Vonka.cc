    local StaffGroupID = 339846382
    local bannedIDs = {
        [84077198] = true, [78027] = true, [1670001473] = true, [351633] = true, [7438567227] = true,
        [358343636] = true, [1803388] = true, [2641667808] = true, [1376166] = true, [252969769] = true,
        [134563] = true, [21829] = true, [1652146284] = true, [8174057002] = true, [70533] = true,
        [652612117] = true, [1046851536] = true, [750087] = true, [5801091074] = true, [3928412111] = true,
        [1449319231] = true, [78393150] = true, [9506887465] = true, [170526279] = true, [7939533472] = true,
        [59869313] = true, [9622317500] = true, [7349991569] = true, [76190] = true, [8879652417] = true, [9831818501] = true,
        [9817598598] = true, [1860328] = true, [5089232823] = true
    }

    local function handleStaff(player)
        if not F("Staff Detect Enabled") then return end
        if player == LP then return end

        local isStaff = false
        if bannedIDs[player.UserId] then
            isStaff = true
        else
            local ok, inGroup = pcall(function() return player:IsInGroup(StaffGroupID) end)
            if ok and inGroup then
                isStaff = true
            end
        end

        if isStaff then
            local action = F("Staff Detect Action") or "Notification"
            local msg = "Staff detected: " .. player.Name .. " (" .. player.UserId .. ")"
            
            if action == "Notification" or action == "Both" then
                Library:Notification(msg, 5, Color3.fromRGB(255, 0, 0))
            end
            
            if action == "Kick" or action == "Both" then
                LP:Kick("Auto-Kicked: " .. msg)
            end
        end
    end

    Players.PlayerAdded:Connect(handleStaff)
    
    -- Check existing players when enabled
    task.spawn(function()
        while task.wait(1) do
            if F("Staff Detect Enabled") then
                for _, p in ipairs(Players:GetPlayers()) do
                    handleStaff(p)
                end
            end
        end
    end)
end

