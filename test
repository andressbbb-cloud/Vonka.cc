do -- Legit / Aimbot Logic
    local Players = game:GetService("Players")
    local RS      = game:GetService("RunService")
    local UIS     = game:GetService("UserInputService")
    local LP      = Players.LocalPlayer
    local Cam     = workspace.CurrentCamera

    -- Abstraction for different executors
    local function mouse_move(x, y)
        if type(mousemoverel) == "function" then
            return mousemoverel(x, y)
        end
        if Input and type(Input.MouseMove) == "function" then
            return Input.MouseMove(x, y)
        end
        if Input and type(Input.MoveMouse) == "function" then
            return Input.MoveMouse(x, y)
        end
    end

    local FOV_Drawings = {
        Circle = makeDrawing("Circle"),
        Square = makeDrawing("Square"),
        Dotted = {} -- for dotted circle
    }
    
    for i = 1, 60 do
        local d = makeDrawing("Line")
        d.Visible = false
        d.Thickness = 1
        table.insert(FOV_Drawings.Dotted, d)
    end

    FOV_Drawings.Circle.Visible = false
    FOV_Drawings.Circle.ZIndex = 5
    FOV_Drawings.Circle.Filled = false

    FOV_Drawings.Square.Visible = false
    FOV_Drawings.Square.ZIndex = 5
    FOV_Drawings.Square.Filled = false

    local currentTarget = nil
    local fovRotation = 0

    local function isTargetValid(v, isCurrentTarget)
        if not v or not v.Character then return false end
        local char = v.Character
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp or hum.Health <= 0 then return false end
        
        -- Checks
        if F("Check Friend") and v.Team == LP.Team then return false end
        
        -- Knock Check
        if F("Check Knock") then
            if char:FindFirstChild("BodyEffects") and char.BodyEffects:FindFirstChild("K.O") and char.BodyEffects["K.O"].Value then return false end
            if char:FindFirstChild("KO") and char.KO.Value then return false end
        end

        local targetPart = char:FindFirstChild(F("Aimbot Part") or "Head")
        if not targetPart then return false end

        local screenPos, onScreen = Cam:WorldToViewportPoint(targetPart.Position)
        
        -- If it's a new target, they MUST be on screen.
        -- If they are already our sticky target, we allow them to go off-screen.
        if not isCurrentTarget and not onScreen then return false end

        -- Wall Check
        if F("Check Wall") then
            local ray = Ray.new(Cam.CFrame.Position, (targetPart.Position - Cam.CFrame.Position).Unit * 500)
            local hit = workspace:FindPartOnRayWithIgnoreList(ray, {LP.Character, char})
            if hit then return false end
        end

        -- FOV Check
        -- If it's already the current sticky target, don't drop them just because they left the tiny FOV circle,
        -- as long as they are still on screen.
        if not isCurrentTarget then
            local mousePos = UIS:GetMouseLocation()
            local mag = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
            if mag > (F("Aimbot FOV") or 120) then return false end
        end

        return true
    end

    local function getClosestPlayer()
        if F("Aimbot Sticky") and currentTarget and isTargetValid(currentTarget, true) then
            return currentTarget
        end

        local target = nil
        local bestValue = math.huge
        local mousePos = UIS:GetMouseLocation()
        local method = F("Aimbot Target Method") or "Closest to Mouse"

        for _, v in ipairs(Players:GetPlayers()) do
            if v == LP then continue end
            if isTargetValid(v, false) then
                local char = v.Character
                local targetPart = char:FindFirstChild(F("Aimbot Part") or "Head")
                local screenPos, _ = Cam:WorldToViewportPoint(targetPart.Position)
                local mag = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                
                local currentValue = math.huge
                
                if method == "Closest to Mouse" then
                    currentValue = mag
                else
                    -- "FOV" method: essentially the same as "Closest to Mouse" 
                    -- but could be prioritized differently if needed.
                    -- In Da Hood, "FOV" usually just means "First target found inside the circle" 
                    -- or "Closest to crosshair". Let's stick to magnitude for stability.
                    currentValue = mag
                end

                if currentValue < bestValue then
                    bestValue = currentValue
                    target = v
                end
            end
        end
        return target
    end

    local function getTargetPos(player)
        local char = player.Character
        local targetPart = char:FindFirstChild(F("Aimbot Part") or "Head")
        if not targetPart then return nil end

        local pos = targetPart.Position
        local vel = targetPart.Velocity

        -- Resolver Methods
        if F("Aimbot Resolver") then
            local resType = F("Aimbot Resolver Type") or "Velocity"
            
            if resType == "Velocity" then
                -- Stabilizes Y axis if they are jumping/falling too fast or spinning
                if vel.Magnitude > 50 or math.abs(vel.Y) > 25 then
                    vel = Vector3.new(vel.X, 0, vel.Z).Unit * 15 
                end
            elseif resType == "No Prediction" then
                -- Force zero velocity to completely ignore their movement
                vel = Vector3.new(0, 0, 0)
            end
        end

        -- Prediction
        if F("Aimbot Prediction") then
            local pred = tonumber(F("Aimbot Prediction Amount")) or 0.15
            pos = pos + (vel * pred)
        end

        return pos
    end

    local function getSmoothAmount(baseAmount, smoothType)
        if baseAmount >= 1 then return 1 end -- 100% means instant snap

        if smoothType == "Linear" then
            return baseAmount
        elseif smoothType == "Exponential" then
            return baseAmount ^ 2
        elseif smoothType == "Quadratic" then
            return baseAmount * (2 - baseAmount)
        elseif smoothType == "Cubic" then
            return baseAmount ^ 3
        elseif smoothType == "Sine" then
            return math.sin(baseAmount * (math.pi / 2))
        elseif smoothType == "Elastic" then
            return math.sin(-13 * math.pi / 2 * (baseAmount + 1)) * math.pow(2, -10 * baseAmount) + 1
        elseif smoothType == "Spring" then
            return 1 - math.exp(-baseAmount * 10) * math.cos(baseAmount * 10)
        end
        return baseAmount
    end

    local function rotateCamera(pos)
        local type = F("Aimbot Type") or "Camera"
        local smooth = F("Aimbot Smooth")
        local baseAmount = (F("Aimbot Smooth Amount") or 20) / 100
        local smoothType = F("Aimbot Smooth Type") or "Exponential"

        local finalAmount = smooth and getSmoothAmount(baseAmount, smoothType) or 1

        if type == "Camera" then
            local targetCF = CFrame.new(Cam.CFrame.Position, pos)
            if smooth then
                Cam.CFrame = Cam.CFrame:Lerp(targetCF, finalAmount)
            else
                Cam.CFrame = targetCF
            end
        else
            -- Mouse Aimbot
            local screenPos, onScreen = Cam:WorldToViewportPoint(pos)
            if onScreen then
                local mousePos = UIS:GetMouseLocation()
                local move = Vector2.new(screenPos.X - mousePos.X, screenPos.Y - mousePos.Y)
                if smooth then
                    mouse_move(move.X * finalAmount, move.Y * finalAmount)
                else
                    mouse_move(move.X, move.Y)
                end
            end
        end
    end

    local lastAimTarget = nil

    RS.RenderStepped:Connect(function(dt)
        -- Update FOV Visuals
        local fovEnabled = F("Aimbot FOV Visible")
        local fovShape = F("Aimbot FOV Shape") or "Circle"
        local fovRadius = F("Aimbot FOV") or 120
        local mousePos = UIS:GetMouseLocation()
        
        -- Animation Logic
        if F("Aimbot FOV Rainbow") then
            local speed = F("Aimbot FOV Rainbow Speed") or 1
            local color = Color3.fromHSV(tick() * speed % 1, 0.8, 1)
            FOV_Drawings.Circle.Color = color
            FOV_Drawings.Square.Color = color
            for _, d in ipairs(FOV_Drawings.Dotted) do d.Color = color end
        else
            local color = F("Aimbot FOV Color") or Color3.fromRGB(255, 0, 0)
            FOV_Drawings.Circle.Color = color
            FOV_Drawings.Square.Color = color
            for _, d in ipairs(FOV_Drawings.Dotted) do d.Color = color end
        end

        if F("Aimbot FOV Spin") then
            fovRotation = fovRotation + (F("Aimbot FOV Spin Speed") or 90) * dt
        end

        -- Visibility cleanup
        FOV_Drawings.Circle.Visible = fovEnabled and (fovShape == "Circle")
        FOV_Drawings.Square.Visible = fovEnabled and (fovShape == "Square")
        for _, d in ipairs(FOV_Drawings.Dotted) do d.Visible = false end

        if fovEnabled then
            if fovShape == "Circle" then
                FOV_Drawings.Circle.Radius = fovRadius
                FOV_Drawings.Circle.Position = mousePos
                FOV_Drawings.Circle.Thickness = F("Aimbot FOV Thickness") or 1
            elseif fovShape == "Square" then
                FOV_Drawings.Square.Size = Vector2.new(fovRadius * 2, fovRadius * 2)
                FOV_Drawings.Square.Position = mousePos - Vector2.new(fovRadius, fovRadius)
                FOV_Drawings.Square.Thickness = F("Aimbot FOV Thickness") or 1
            elseif fovShape == "Dotted Circle" then
                local numDots = #FOV_Drawings.Dotted
                for i = 1, numDots do
                    local d = FOV_Drawings.Dotted[i]
                    local angle = math.rad((i / numDots) * 360 + fovRotation)
                    local p1 = mousePos + Vector2.new(math.cos(angle), math.sin(angle)) * fovRadius
                    local p2 = mousePos + Vector2.new(math.cos(angle + 0.05), math.sin(angle + 0.05)) * fovRadius
                    d.From = p1
                    d.To = p2
                    d.Visible = true
                end
            end
        end

        -- Aimbot Logic
        local isAiming = active("Aimbot Enabled", "Aimbot Key")
        local previousTarget = currentTarget
        
        if isAiming then
            if F("Aimbot Sticky") then
                if not currentTarget or not isTargetValid(currentTarget, true) then
                    currentTarget = getClosestPlayer()
                end
            else
                currentTarget = getClosestPlayer()
            end

            if currentTarget then
                local pos = getTargetPos(currentTarget)
                if pos then
                    -- Shake
                    if F("Aimbot Shake") then
                        local intensity = (F("Aimbot Shake Intensity") or 1) / 5
                        local pattern = F("Aimbot Shake Pattern") or "Random"
                        local offset = Vector3.new(0, 0, 0)
                        
                        if pattern == "Random" then
                            offset = Vector3.new(math.random(-100, 100), math.random(-100, 100), math.random(-100, 100)) * (intensity / 100)
                        elseif pattern == "Circular" then
                            offset = Vector3.new(math.sin(tick() * 10), math.cos(tick() * 10), 0) * intensity
                        elseif pattern == "Horizontal" then
                            offset = Vector3.new(math.sin(tick() * 15), 0, 0) * intensity
                        elseif pattern == "Vertical" then
                            offset = Vector3.new(0, math.sin(tick() * 15), 0) * intensity
                        end
                        pos = pos + offset
                    end
                    rotateCamera(pos)
                end
            end
        else
            currentTarget = nil
        end
    end)
end

do -- Silent Aim Logic
    local RS = game:GetService("RunService")
    local Players = game:GetService("Players")
    local LP = Players.LocalPlayer
    local Cam = workspace.CurrentCamera
    local UIS = game:GetService("UserInputService")
    
    local silentTarget = nil
    local silentTargetPart = nil
    
    local dotDrawing = makeDrawing("Circle")
    dotDrawing.Filled = true
    dotDrawing.Radius = 3
    dotDrawing.Transparency = 1
    dotDrawing.Visible = false

    local SilentFOV_Drawings = {
        Circle = makeDrawing("Circle"),
        Square = makeDrawing("Square"),
        Dotted = {}
    }
    for i = 1, 16 do
        table.insert(SilentFOV_Drawings.Dotted, makeDrawing("Line"))
    end
    local silentFovRotation = 0

    local function isSilentTargetValid(player)
        if not player or not player.Character then return false end
        local char = player.Character
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp or hum.Health <= 0 then return false end

        -- Checks
        if F("Silent Check Friend") and player.Team == LP.Team then return false end
        if F("Silent Check Knock") then
            if char:FindFirstChild("BodyEffects") and char.BodyEffects:FindFirstChild("K.O") and char.BodyEffects["K.O"].Value then return false end
            if char:FindFirstChild("KO") and char.KO.Value then return false end
        end

        return true
    end

    local function getSilentTargetPos(targetPart)
        if not targetPart or typeof(targetPart) ~= "Instance" or not targetPart:IsA("BasePart") then return nil end

        local pos = targetPart.Position
        local vel = targetPart.AssemblyLinearVelocity

        -- Resolver Methods
        if F("Silent Resolver") then
            local resType = F("Silent Resolver Type") or "Velocity"
            
            if resType == "Velocity" then
                if vel.Magnitude > 50 or math.abs(vel.Y) > 25 then
                    vel = Vector3.new(vel.X, 0, vel.Z).Unit * 15 
                end
            elseif resType == "No Prediction" then
                vel = Vector3.new(0, 0, 0)
            end
        end

        -- Prediction
        if F("Silent Prediction") then
            local pred = tonumber(F("Silent Prediction Amount")) or 0.15
            pos = pos + (vel * pred)
        end

        return pos
    end

    local function getSilentTarget()
        local method = F("Silent Target Method") or "Closest to Mouse"
        local target = nil
        local bestValue = math.huge
        local mousePos = UIS:GetMouseLocation()
        local bestPartForTarget = nil

        local isClosestPart = F("Silent Closest Part")
        local partsList = F("Silent Part") or {"Head"}
        if type(partsList) ~= "table" then partsList = {partsList} end

        for _, v in ipairs(Players:GetPlayers()) do
            if v == LP then continue end
            if isSilentTargetValid(v) then
                local char = v.Character
                
                local partsToCheck = {}
                if isClosestPart then
                    for _, child in ipairs(char:GetChildren()) do
                        if child:IsA("BasePart") then
                            table.insert(partsToCheck, child)
                        end
                    end
                else
                    for _, pName in ipairs(partsList) do
                        local p = char:FindFirstChild(pName)
                        if p then table.insert(partsToCheck, p) end
                    end
                end
                
                if #partsToCheck == 0 then
                    local backup = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                    if backup then table.insert(partsToCheck, backup) end
                end

                for _, tPart in ipairs(partsToCheck) do
                    local screenPos, onScreen = Cam:WorldToViewportPoint(tPart.Position)
                    
                    -- Wall Check
                    if F("Silent Check Wall") then
                        local ray = Ray.new(Cam.CFrame.Position, (tPart.Position - Cam.CFrame.Position).Unit * 500)
                        local hit = workspace:FindPartOnRayWithIgnoreList(ray, {LP.Character, char})
                        if hit then continue end
                    end

                    if method == "Closest to Mouse" or method == "FOV" then
                        if onScreen then
                            local mag = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                            
                            -- Silent FOV limit check
                            local fovRadius = F("Silent FOV") or 120
                            if method == "Closest to Mouse" or (method == "FOV" and mag <= fovRadius) then
                                if mag < bestValue then
                                    bestValue = mag
                                    target = v
                                    bestPartForTarget = tPart
                                end
                            end
                        end
                    elseif method == "Closest Player" then
                        local lpChar = LP.Character
                        local lpRoot = lpChar and lpChar:FindFirstChild("HumanoidRootPart")
                        if lpRoot then
                            local dist = (tPart.Position - lpRoot.Position).Magnitude
                            if dist < bestValue then
                                bestValue = dist
                                target = v
                                bestPartForTarget = tPart
                            end
                        end
                    end
                end
            end
        end
        silentTargetPart = bestPartForTarget
        return target
    end

    RS.RenderStepped:Connect(function(dt)
        -- Update Silent FOV Visuals
        local fovEnabled = F("Silent FOV Visible")
        local fovShape = F("Silent FOV Shape") or "Circle"
        local fovRadius = F("Silent FOV") or 120
        local mousePos = UIS:GetMouseLocation()
        
        -- Animation Logic
        if F("Silent FOV Rainbow") then
            local speed = F("Silent FOV Rainbow Speed") or 1
            local color = Color3.fromHSV(tick() * speed % 1, 0.8, 1)
            SilentFOV_Drawings.Circle.Color = color
            SilentFOV_Drawings.Square.Color = color
            for _, d in ipairs(SilentFOV_Drawings.Dotted) do d.Color = color end
        else
            local color = F("Silent FOV Color") or Color3.fromRGB(255, 0, 0)
            SilentFOV_Drawings.Circle.Color = color
            SilentFOV_Drawings.Square.Color = color
            for _, d in ipairs(SilentFOV_Drawings.Dotted) do d.Color = color end
        end

        if F("Silent FOV Spin") then
            silentFovRotation = silentFovRotation + (F("Silent FOV Spin Speed") or 90) * dt
        end

        -- Visibility cleanup
        SilentFOV_Drawings.Circle.Visible = fovEnabled and (fovShape == "Circle")
        SilentFOV_Drawings.Square.Visible = fovEnabled and (fovShape == "Square")
        for _, d in ipairs(SilentFOV_Drawings.Dotted) do d.Visible = false end

        if fovEnabled then
            if fovShape == "Circle" then
                SilentFOV_Drawings.Circle.Radius = fovRadius
                SilentFOV_Drawings.Circle.Position = mousePos
                SilentFOV_Drawings.Circle.Thickness = F("Silent FOV Thickness") or 1
            elseif fovShape == "Square" then
                SilentFOV_Drawings.Square.Size = Vector2.new(fovRadius * 2, fovRadius * 2)
                SilentFOV_Drawings.Square.Position = mousePos - Vector2.new(fovRadius, fovRadius)
                SilentFOV_Drawings.Square.Thickness = F("Silent FOV Thickness") or 1
            elseif fovShape == "Dotted Circle" then
                local numDots = #SilentFOV_Drawings.Dotted
                for i = 1, numDots do
                    local d = SilentFOV_Drawings.Dotted[i]
                    local angle = math.rad((i / numDots) * 360 + silentFovRotation)
                    local p1 = mousePos + Vector2.new(math.cos(angle), math.sin(angle)) * fovRadius
                    local p2 = mousePos + Vector2.new(math.cos(angle + 0.05), math.sin(angle + 0.05)) * fovRadius
                    d.From = p1
                    d.To = p2
                    d.Visible = true
                end
            end
        end

        if not active("Silent Enabled", "Silent Key") then
            silentTarget = nil
            dotDrawing.Visible = false
            return
        end

        local prevTarget = silentTarget
        silentTarget = getSilentTarget()

        if F("Silent Target Indicator") and _G.VonkaIndicatorUI and _G.VonkaIndicatorUI.Update then 
            _G.VonkaIndicatorUI.Update(silentTarget, true) 
        end

        if F("Silent Notifications") and silentTarget ~= prevTarget then
            if silentTarget then
                Library:Notification("Silent Aim Locked: " .. silentTarget.Name, 2, Color3.fromRGB(0, 255, 100))
            elseif prevTarget then
                Library:Notification("Silent Aim Target lost", 1, Color3.fromRGB(255, 50, 50))
            end
        end

        if silentTarget and silentTargetPart and silentTarget.Character then
            if F("Silent Target Dot") then
                local screenPos, onScreen = Cam:WorldToViewportPoint(silentTargetPart.Position)
                if onScreen then
                    dotDrawing.Position = Vector2.new(screenPos.X, screenPos.Y)
                    
                    if F("Silent Dot Dynamic Color") then
                        dotDrawing.Color = silentTargetPart.Color
                    else
                        dotDrawing.Color = F("Silent Target Dot Color") or Color3.fromRGB(255, 0, 0)
                    end
                    
                    dotDrawing.Visible = true
                else
                    dotDrawing.Visible = false
                end
            else
                dotDrawing.Visible = false
            end
        else
            dotDrawing.Visible = false
        end
    end)
    
    -- Da Hood specific Hook Setup for Silent Aim
    if type(hookmetamethod) == "function" and type(checkcaller) == "function" then
        local oldNamecall
        local oldIndex
        
        pcall(function()
            -- Hook __index for Mouse.Hit and Mouse.Target
            oldIndex = hookmetamethod(game, "__index", function(self, key)
                if not checkcaller() and active("Silent Enabled", "Silent Key") and silentTarget and silentTargetPart then
                    if typeof(self) == "Instance" and self:IsA("Mouse") then
                        if key == "Hit" then
                            local hitPos = getSilentTargetPos(silentTargetPart) or silentTargetPart.Position
                            return CFrame.new(hitPos)
                        elseif key == "Target" then
                            return silentTargetPart
                        end
                    end
                end
                return oldIndex(self, key)
            end)
            
            -- Hook __namecall for MainEvent args
            oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
                local method = getnamecallmethod()
                local rawArgs = {...}
                local function callOldWithFallback(argsToSend)
                    local ok, result = pcall(function()
                        return oldNamecall(self, unpack(argsToSend))
                    end)
                    if ok then
                        return result
                    end
                    return oldNamecall(self, unpack(rawArgs))
                end

                -- Track real local shots from outgoing Shoot packets.
                if not checkcaller()
                    and method == "FireServer"
                    and typeof(self) == "Instance"
                    and self:IsA("RemoteEvent")
                    and self.Name == "MainEvent"
                    and rawArgs[1] == "Shoot" then
                    _G.VonkaLastLocalShot = tick()

                    if _G.VonkaBeamSpawn then
                        local myChar = LP.Character
                        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
                        local fromPos = myRoot and myRoot.Position or nil
                        local targetPos = nil
                        local packet = rawArgs[2]

                        if type(packet) == "table" and type(packet[1]) == "table" and type(packet[1][1]) == "table" then
                            local hit = packet[1][1]
                            if typeof(hit.Position) == "Vector3" then
                                targetPos = hit.Position
                            elseif typeof(hit.Instance) == "Instance" and hit.Instance:IsA("BasePart") then
                                targetPos = hit.Instance.Position
                            end
                        end

                        if typeof(targetPos) ~= "Vector3" then
                            local mouse = LP:GetMouse()
                            if mouse and mouse.Hit then
                                targetPos = mouse.Hit.Position
                            end
                        end

                        if typeof(fromPos) == "Vector3" and typeof(targetPos) == "Vector3" then
                            pcall(function() _G.VonkaBeamSpawn(fromPos, targetPos) end)
                        end
                    end
                end
                
                if not checkcaller() and active("Silent Enabled", "Silent Key") and silentTarget and silentTargetPart then
                    local hitPos = getSilentTargetPos(silentTargetPart) or silentTargetPart.Position
                    
                    if typeof(self) == "Instance" then
                        -- Handle Raycast interception (generic for many games)
                        if method == "Raycast" and self == workspace then
                            local args = {...}
                            local origin = args[1]
                            if typeof(origin) == "Vector3" then
                                local newDirection = (hitPos - origin).Unit * (args[2].Magnitude or 1000)
                                args[2] = newDirection
                                return callOldWithFallback(args)
                            end
                        end
                        
                        -- Handle RemoteEvents (scoped: avoid corrupting unrelated packets)
                        if self:IsA("RemoteEvent") and method == "FireServer" and self.Name == "MainEvent" then
                            local args = {...}

                            -- Only rewrite known aim fields; blanket Vector3 replacement can break game effects.
                            if args[1] == "MousePosUpdate" then
                                args[2] = hitPos
                            end

                            return callOldWithFallback(args)
                        end
                    end
                end
                return callOldWithFallback(rawArgs)
            end)
        end)
    end
end

do -- Force Logic
    local RS      = game:GetService("RunService")
    local LP      = game:GetService("Players").LocalPlayer

    local lastForceFire = 0
    local mainEvent = nil
    
    local GUN_TOOL_NAMES = {
        "[Revolver]",
        "[DoubleBarrel]",
        "[Shotgun]",
        "[Silencer]",
        "[TacticalShotgun]",
        "[SMG]",
        "[Flintlock]",
        "[Firework Launcher]",
    }

    local forceTargetLine = makeDrawing("Line")
    forceTargetLine.Visible = false
    forceTargetLine.Thickness = 1.5
    forceTargetLine.Color = Color3.fromRGB(255, 0, 0)
    forceTargetLine.ZIndex = 2

    local function getEquippedGun()
        local myChar = LP.Character
        if not myChar then return nil end
        local tool = myChar:FindFirstChildOfClass("Tool")
        if tool then
            -- First check exact names
            for _, name in ipairs(GUN_TOOL_NAMES) do
                if tool.Name == name then return tool end
            end
        end
        return nil
    end

    -- Function to find the main remote event (common in Da Hood games)
    local function getMainEvent()
        if mainEvent then return mainEvent end
        mainEvent = game:GetService("ReplicatedStorage"):WaitForChild("MainEvent")
        if not mainEvent then
            -- fallback search
            for _, v in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
                if v:IsA("RemoteEvent") and (v.Name == "MainEvent" or v.Name == "Remote") then
                    mainEvent = v
                    break
                end
            end
        end
        return mainEvent
    end

    local currentTargetPlayer = nil

    local function isForceTargetValid(p)
        if not p or not p.Character then return false end
        local myChar = LP.Character
        if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return false end
        
        local char = p.Character
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp or hum.Health <= 0 then return false end
        
        if F("Force FF Check") and char:FindFirstChildOfClass("ForceField") then return false end
        if F("Force Knock Check") then
            if char:FindFirstChild("BodyEffects") and char.BodyEffects:FindFirstChild("K.O") and char.BodyEffects["K.O"].Value then return false end
            if char:FindFirstChild("KO") and char.KO.Value then return false end
        end
        
        local distToPlayer = (hrp.Position - myChar.HumanoidRootPart.Position).Magnitude
        local maxRange = F("Force Range") or 1000
        if distToPlayer > maxRange then return false end
        
        return true
    end

    local function getForceTarget()
        local myChar = LP.Character
        if not myChar then return nil end
        
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return nil end

        local players = game:GetService("Players"):GetPlayers()
        local closest = nil
        local maxRange = F("Force Range") or 1000
        
        local myPos = myRoot.Position
        
        -- Sticky Target Logic: Always stay on the target if we already have one
        if currentTargetPlayer and isForceTargetValid(currentTargetPlayer) then
            return currentTargetPlayer
        end

        local mouse = LP:GetMouse()
        local mousePos = Vector2.new(mouse.X, mouse.Y)
        local minMouseDist = math.huge
        local Cam = workspace.CurrentCamera

        for _, p in ipairs(players) do
            if p == LP then continue end
            if isForceTargetValid(p) then
                local hrp = p.Character.HumanoidRootPart
                local screenPos, onScreen = Cam:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local distToMouse = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    if distToMouse < minMouseDist then
                        minMouseDist = distToMouse
                        closest = p
                    end
                end
            end
        end
        return closest
    end

    RS.RenderStepped:Connect(function()
        if not active("Force Enabled", "Force Key") then 
            currentTargetPlayer = nil
            forceTargetLine.Visible = false
            if _G.VonkaIndicatorUI and _G.VonkaIndicatorUI.Update then 
                _G.VonkaIndicatorUI.Update(nil, false) 
            end
            return 
        end
        
        -- Always update target based on mouse position
        currentTargetPlayer = getForceTarget()
        
        if F("Force Target Indicator") and _G.VonkaIndicatorUI and _G.VonkaIndicatorUI.Update then 
            _G.VonkaIndicatorUI.Update(currentTargetPlayer, true) 
        end
        
        -- Target Line Visual
        if F("Force Target Line") and currentTargetPlayer and currentTargetPlayer.Character then
            local enemyChar = currentTargetPlayer.Character
            local targetPart = enemyChar:FindFirstChild(F("Force Target Part") or "Head") or enemyChar:FindFirstChild("HumanoidRootPart")
            if targetPart then
                local Cam = workspace.CurrentCamera
                local screenPos, onScreen = Cam:WorldToViewportPoint(targetPart.Position)
                if onScreen then
                    local mousePos = game:GetService("UserInputService"):GetMouseLocation()
                    forceTargetLine.From = Vector2.new(screenPos.X, screenPos.Y)
                    forceTargetLine.To = mousePos
                    forceTargetLine.Color = F("Force Target Line Color") or Color3.fromRGB(255, 0, 0)
                    forceTargetLine.Visible = true
                else
                    forceTargetLine.Visible = false
                end
            else
                forceTargetLine.Visible = false
            end
        else
            forceTargetLine.Visible = false
        end
    end)

    RS.Heartbeat:Connect(function()
        if not active("Force Enabled", "Force Key") then 
            return 
        end
        
        local currentGun = getEquippedGun()
        if not currentGun then 
            return 
        end
        
        local now = tick()
        local rawCooldown = F("Force Cooldown")
        local cooldown = (type(rawCooldown) == "number" and rawCooldown) or 1.2
        cooldown = math.max(1.0, cooldown) -- force cadence similar to stable DB script
        
        if now - lastForceFire < cooldown then return end
        
        if not currentTargetPlayer then return end
        
        local enemyChar = currentTargetPlayer.Character
        if not enemyChar then return end
        local tRoot = enemyChar:FindFirstChild("HumanoidRootPart")
        if not tRoot then return end
        
        local partName = F("Force Target Part") or "Head"
        local targetPart = enemyChar:FindFirstChild(partName) or tRoot
        local event = getMainEvent()
        if not event then return end

        local myChar = LP.Character
        if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
        
        local myRoot = myChar.HumanoidRootPart
        if not targetPart or not targetPart:IsA("BasePart") or not targetPart:IsDescendantOf(workspace) then return end

        local myPos = myRoot.Position
        local targetPos = targetPart.Position
        if not isVectorValid(myPos) or not isVectorValid(targetPos) then return end

        lastForceFire = now

        local function shootOnce()
            if not targetPart or not targetPart:IsA("BasePart") or not targetPart:IsDescendantOf(workspace) then return end
            targetPos = targetPart.Position
            if not isVectorValid(targetPos) then return end
            local args = {
                [1] = "Shoot",
                [2] = {
                    [1] = {
                        [1] = { Normal = targetPos, Instance = targetPart, Position = targetPos },
                        [2] = { Normal = targetPos, Instance = targetPart, Position = targetPos },
                        [3] = { Normal = targetPos, Instance = targetPart, Position = targetPos },
                        [4] = { Normal = targetPos, Instance = targetPart, Position = targetPos },
                        [5] = { Normal = targetPos, Instance = targetPart, Position = targetPos },
                    },
                    [2] = {
                        [1] = { thePart = targetPart, theOffset = Vector3.new(0, 0, 0) },
                        [2] = { thePart = targetPart, theOffset = Vector3.new(0, 0, 0) },
                        [3] = { thePart = targetPart, theOffset = Vector3.new(0, 0, 0) },
                        [4] = { thePart = targetPart, theOffset = Vector3.new(0, 0, 0) },
                        [5] = { thePart = targetPart, theOffset = Vector3.new(0, 0, 0) },
                    },
                    [3] = myPos,
                    [4] = myPos,
                    [5] = workspace:GetServerTimeNow(),
                },
            }
            pcall(function() event:FireServer(unpack(args)) end)
        end

        -- Keep one packet per cycle; burst spam causes dropped unreliable events and client errors.
        local burstCount = 1

        for i = 1, burstCount do
            shootOnce()
            if i < burstCount then
                task.wait(0.02)
            end
        end

        if F("Force Auto Reload") then
            task.spawn(function()
                task.wait(0.1)
                -- check if we still have the same gun equipped for reload
                local gunToReload = getEquippedGun()
                if gunToReload and gunToReload == currentGun then
                    pcall(function() event:FireServer("Reload", gunToReload) end)
                end
            end)
        end
    end)
end

