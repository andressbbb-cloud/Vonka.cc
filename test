        end
        if not hrp or not hum then return end
        hum.AutoRotate = false
        local spd = (F("Misc Spinbot Speed") or 50) * (1/3)
        hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(spd), 0)
    end)

    -- ── VOID SPAM ────────────────────────────────────────────────────────────
    local void = {
        enabled = false,
        client_root = nil,
        saved_cframe = nil,
        hook = nil,
        timer = 0,
        is_voided = false,
        angle = 0,
        radius = 1000, -- Capped for safety
        spin_speed = 50,
        speed = 1
    }

    local function isVectorValid(v)
        if typeof(v) ~= "Vector3" then return false end
        return v.X == v.X and v.Y == v.Y and v.Z == v.Z and 
               v.X ~= math.huge and v.X ~= -math.huge and
               v.Y ~= math.huge and v.Y ~= -math.huge and
               v.Z ~= math.huge and v.Z ~= -math.huge
    end

    local function getSpoofState()
        if void.enabled and void.saved_cframe and void.client_root and void.client_root.Parent then
            return void
        end
    end

    local function enable_hook()
        if not void.hook and type(hookmetamethod) == "function" and type(checkcaller) == "function" then
            local original
            local ok, result = pcall(function()
                original = hookmetamethod(game, "__index", function(self, index)
                    if not checkcaller() and index == "CFrame" then
                        local spoofState = getSpoofState()
                        if spoofState and self == spoofState.client_root then
                            local saved = spoofState.saved_cframe
                            if saved then return saved end
                        end
                    end
                    return original(self, index)
                end)
                return original
            end)
            if ok and result then
                void.hook = result
            end
        end
    end

    local function disable_hook()
        -- Leaving the hook active to avoid unhookmetamethod crashes.
        -- The logic inside enable_hook already respects getSpoofState().
    end

    local NUM_LINES = 30
    local lines = {}
    local coreLine = makeDrawing("Line")
    local arrowLeft = makeDrawing("Line")
    local arrowRight = makeDrawing("Line")
    local trailHistory = {}

    local function setupDrawings()
        for i = 1, NUM_LINES do
            local l = makeDrawing("Line")
            l.Visible = false
            local t = i / NUM_LINES
            l.Color = Color3.fromRGB(255, math.floor(t * 180), math.floor(t * 20))
            l.Thickness = math.max(0.5, (1 - t) * 4)
            l.Transparency = 1 - (1 - t) * 0.9
            table.insert(lines, l)
        end

        coreLine.Visible = false
        coreLine.Color = Color3.fromRGB(255, 255, 255)
        coreLine.Thickness = 1
        coreLine.Transparency = 1

        arrowLeft.Visible = false
        arrowLeft.Color = Color3.fromRGB(255, 255, 255)
        arrowLeft.Thickness = 1.5
        arrowLeft.Transparency = 1

        arrowRight.Visible = false
        arrowRight.Color = Color3.fromRGB(255, 255, 255)
        arrowRight.Thickness = 1.5
        arrowRight.Transparency = 1

        for i = 1, NUM_LINES + 1 do
            trailHistory[i] = Vector2.new(0, 0)
        end
    end
    setupDrawings()

    local function cleanDrawings()
        for _, l in ipairs(lines) do
            l.Visible = false
        end
        coreLine.Visible = false
        arrowLeft.Visible = false
        arrowRight.Visible = false
        for i = 1, #trailHistory do
            trailHistory[i] = Vector2.new(0, 0)
        end
    end

    local function updateLines(fromPos, toPos)
        local cam = workspace.CurrentCamera
        local toScreen, toVis = cam:WorldToViewportPoint(toPos)
        local fromScreen, fromVis = cam:WorldToViewportPoint(fromPos)

        if not fromVis then
            cleanDrawings()
            return
        end

        local headPos = Vector2.new(toScreen.X, toScreen.Y)
        local originPos = Vector2.new(fromScreen.X, fromScreen.Y)

        table.insert(trailHistory, 1, headPos)
        if #trailHistory > NUM_LINES + 1 then
            table.remove(trailHistory)
        end

        for i = 1, NUM_LINES do
            local l = lines[i]
            if trailHistory[i] and trailHistory[i + 1] then
                l.From = trailHistory[i + 1]
                l.To = trailHistory[i]
                l.Visible = true
            end
        end

        coreLine.From = trailHistory[2] or headPos
        coreLine.To = headPos
        coreLine.Visible = true

        local dir = headPos - originPos
        local len = dir.Magnitude
        if len > 1 then
            dir = dir / len
            local perp = Vector2.new(-dir.Y, dir.X)
            local arrowSize = 12
            arrowLeft.From = headPos
            arrowLeft.To = headPos - dir * arrowSize + perp * (arrowSize * 0.5)
            arrowLeft.Visible = true
            arrowRight.From = headPos
            arrowRight.To = headPos - dir * arrowSize - perp * (arrowSize * 0.5)
            arrowRight.Visible = true
        end
    end

    local function getSpinTarget()
        if not void.saved_cframe then return Vector3.new(0, 0, 0) end
        local a = void.angle
        local r = void.radius
        local mode = F("Misc Void Mode") or "Spin"
        local basePos = void.saved_cframe.Position
        
        local target
        if mode == "Spin" then
            local x = basePos.X + r * math.sin(a) * math.cos(a * 0.7)
            local y = basePos.Y + r * math.sin(a * 1.3)
            local z = basePos.Z + r * math.cos(a) * math.sin(a * 0.5)
            target = Vector3.new(x, y, z)
        elseif mode == "Random" then
            target = basePos + Vector3.new(math.random(-r, r), math.random(-r, r), math.random(-r, r))
        elseif mode == "Static" then
            target = basePos + Vector3.new(0, r, 0)
        else
            target = basePos
        end
        return isVectorValid(target) and target or basePos
    end

    RS.Heartbeat:Connect(function(delta)
        void.enabled = active("Misc Void Spam", "Misc Void Spam Key")
        void.client_root = hrp
        
        if not void.client_root then return end

        local toolEquipped = char and char:FindFirstChildOfClass("Tool")
        local stopOnTool = F("Misc Void Stop on Tool")

        if void.enabled and not (stopOnTool and toolEquipped) then
            enable_hook()

            void.spin_speed = (F("Misc Void Speed") or 50)
            void.radius = math.clamp(F("Misc Void Radius") or 1000, 0, 1000)
            void.angle = (void.angle + (delta * void.spin_speed * void.speed)) % (math.pi * 2)
            void.timer = void.timer + (delta * void.speed)

            local voidType = F("Misc Void Type") or "Void Spam"
            local void_time = F("Misc Void Time") or 0.05
            local normal_time = F("Misc Normal Time") or 0.05
            local threshold = void.is_voided and void_time or normal_time

            if voidType == "Void Spam" then
                if void.timer >= threshold then
                    void.timer = 0
                    void.is_voided = not void.is_voided
                end
            else
                void.is_voided = true
            end

            void.saved_cframe = void.client_root.CFrame
            local currentTarget = getSpinTarget()

            local target_cframe = (void.is_voided and isVectorValid(currentTarget))
                and CFrame.new(currentTarget)
                or void.saved_cframe

            void.client_root.CFrame = target_cframe

            if void.is_voided and F("Misc Void Show Visuals") then
                pcall(function() updateLines(void.saved_cframe.Position, currentTarget) end)
            else
                pcall(cleanDrawings)
            end

            local restoreRoot = void.client_root
            local restoreCFrame = void.saved_cframe
            task.defer(function()
                if restoreRoot and restoreCFrame and restoreRoot.Parent then
                    pcall(function()
                        restoreRoot.CFrame = restoreCFrame
                    end)
                end
            end)
        else
            void.saved_cframe = nil
            if not getSpoofState() then
                disable_hook()
            end
            cleanDrawings()
        end
    end)

    local ANIM_IDS = {
        Floss = "10714340543", 
        Hype = "10714369624"
    }
    local animObj, loadedAnim, currentTrack

    -- Stops any currently playing custom animations
    local function stopAnim()
        if currentTrack then pcall(function() currentTrack:Stop() end); currentTrack = nil end
        if loadedAnim   then pcall(function() loadedAnim:Stop() end);   loadedAnim = nil end
        if animObj      then pcall(function() animObj:Destroy() end);   animObj = nil end
    end

    -- Loads and plays a custom animation on the player's character
    local function playAnim()
        if not F("Misc Anim Player") then 
            stopAnim() 
            return 
        end
        
        stopAnim()
        local animType = F("Misc Anim Type") or "Chibi"
        local id
        
        if animType == "Custom" then
            local raw = tostring(F("Misc Anim ID") or "")
            id = raw:match("%d+")
            if not id or id == "" then return end
        else
            id = ANIM_IDS[animType] or ANIM_IDS.Chibi
        end
        
        task.spawn(function()
            local c = LP.Character
            if not c then return end
            
            local h = c:FindFirstChildOfClass("Humanoid")
            if not h or h.Health <= 0 then return end
            
            -- Use Animator if possible (standard way for modern Roblox)
            local a = h:FindFirstChildOfClass("Animator") or Instance.new("Animator", h)
            
            local newAnim = Instance.new("Animation")
            newAnim.AnimationId = "rbxassetid://" .. id
            newAnim.Parent = h
            animObj = newAnim
            
            local ok, track = pcall(function() return a:LoadAnimation(newAnim) end)
            if not ok or not track then return end
            
            -- Final check before playing in case toggle was disabled during load
            if not F("Misc Anim Player") then 
                track:Destroy()
                return 
            end
            
            stopAnim()
            currentTrack = track
            currentTrack.Looped = true
            currentTrack:Play()
            currentTrack:AdjustSpeed(F("Misc Anim Speed") or 1)
        end)
    end

    local lastAnimState = false
    _G.VonkaPlayAnim = playAnim
    
    RS.Heartbeat:Connect(function()
        local on = F("Misc Anim Player") and true or false
        if on ~= lastAnimState then
            lastAnimState = on
            if on then playAnim() else stopAnim() end
        end
    end)
    
    -- Re-play animation after respawn without resetting the toggle
    local lastRespawnAnim = 0
    LP.CharacterAdded:Connect(function(c)
        char = c
        hrp  = c:WaitForChild("HumanoidRootPart", 10)
        hum  = c:WaitForChild("Humanoid", 10)
        
        -- Wait until appearance is loaded to be safe before playing animations
        if not LP:HasAppearanceLoaded() then LP.CharacterAppearanceLoaded:Wait() end
        
        if F("Misc Anim Player") and tick() - lastRespawnAnim > 2 then
            lastRespawnAnim = tick()
            task.wait(1) -- Small buffer to let the character initialize
            pcall(function() playAnim() end)
        end
    end)

