    -- Inline flag reader: avoids repeated table-type checks
    local function F(flag)
        local v = (Flags and Flags[flag])
        if v == nil then return false end
        if type(v) == "table" then
            local res = v.Color or v.Key or v
            return (res == nil and false or res)
        end
        return v
    end

    -- Drawing constructors
    local function L()  local d=makeDrawing("Line");   d.Visible=false;d.Thickness=1;d.Color=Color3.fromRGB(255,255,255);return d end
    local function Sq() local d=makeDrawing("Square"); d.Visible=false;d.Thickness=1;d.Filled=false;d.Color=Color3.fromRGB(255,255,255);return d end
    local function Tx() local d=makeDrawing("Text");   d.Visible=false;d.Size=14;d.Center=true;d.Outline=true;d.Color=Color3.fromRGB(255,255,255);return d end
    local function Ba() local d=makeDrawing("Square"); d.Visible=false;d.Filled=true;d.Thickness=1;return d end
    local function Ci() local d=makeDrawing("Circle"); d.Visible=false;d.Thickness=1;d.Filled=false;d.Color=Color3.fromRGB(255,0,0);return d end

    local R15={{"Head","UpperTorso"},{"UpperTorso","LowerTorso"},{"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},{"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},{"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},{"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"}}
    local R6={{"Head","Torso"},{"Torso","Right Arm"},{"Torso","Left Arm"},{"Torso","Right Leg"},{"Torso","Left Leg"}}
    local BMAX = #R15

    local objs   = {}
    local leaving = {}

    -- Cache body parts for a character so we don't call FindFirstChild every frame
    local function cacheCharParts(char)
        local isR15 = char:FindFirstChild("UpperTorso") ~= nil
        local bones = isR15 and R15 or R6
        local boneParts = {}
        for i = 1, BMAX do
            local pair = bones[i]
            if pair then
                boneParts[i] = {char:FindFirstChild(pair[1]), char:FindFirstChild(pair[2])}
            end
        end
        -- cache all BaseParts for bounds + chams (exclude HRP)
        local parts = {}
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then
                parts[#parts+1] = p
            end
        end
        return boneParts, parts
    end

    -- Initializes an ESP object for a player
    local function mk(player)
        if leaving[player] then return end
        if objs[player] then return end -- already exists
        
        -- Master object holding all drawing elements for a player
        local obj = {
            boxL = {L(), L(), L(), L(), L(), L(), L(), L()}, 
            boxO = {L(), L(), L(), L(), L(), L(), L(), L()},
            boxFill = Sq(),
            trOut = L(), 
            tr = L(),
            nm = Tx(), 
            dn = Tx(), 
            dist = Tx(), 
            tool = Tx(),
            hpBG = Ba(), 
            hpBar = Ba(), 
            hpTxt = Tx(),
            
            -- Caches for parts to improve performance
            boneParts = nil, 
            parts = nil,
            chamsApplied = false, 
            chamsColor = nil,
            
            -- Tool state
            toolName = "", 
            toolConn = nil, 
            toolConn2 = nil, 
            charConn = nil,
        }
        objs[player] = obj
        
        -- Connect character caching events
        local function onChar(char)
            if not objs[player] then return end
            task.spawn(function()
                -- Wait for character to fully load (appearance + all parts)
                local hum = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 10)
                if not hum then return end
                
                -- Wait until HRP exists and character is in workspace
                local hrp = char:FindFirstChild("HumanoidRootPart") or char:WaitForChild("HumanoidRootPart", 10)
                if not hrp then return end
                
                -- Small wait to let all descendant parts replicate over the network
                task.wait(0.5)
                if not objs[player] then return end
                
                -- Cache the parts to avoid GetDescendants() calls every frame
                local bp, pts = cacheCharParts(char)
                obj.boneParts = bp
                obj.parts = pts
                obj.chamsApplied = false
                obj.chamsColor = nil
                obj.toolName = ""
                
                -- Clear old tool connections
                if obj.toolConn then obj.toolConn:Disconnect(); obj.toolConn = nil end
                if obj.toolConn2 then obj.toolConn2:Disconnect(); obj.toolConn2 = nil end
                
                -- Listen for tool equip/unequip
                obj.toolConn = char.ChildAdded:Connect(function(c)
                    if c:IsA("Tool") then obj.toolName = c.Name end
                end)
                obj.toolConn2 = char.ChildRemoved:Connect(function(c)
                    if c:IsA("Tool") and obj.toolName == c.Name then obj.toolName = "" end
                end)
                
                -- Check currently equipped tool
                for _, c in ipairs(char:GetChildren()) do
                    if c:IsA("Tool") then 
                        obj.toolName = c.Name
                        break 
                    end
                end
            end)
        end
        
        if player.Character then onChar(player.Character) end
        obj.charConn = player.CharacterAdded:Connect(onChar)
    end

    -- Removes a player's ESP object and cleans up drawings/events
    local function rm(player)
        local obj = objs[player]
        if not obj then return end
        
        -- Disconnect events first
        if obj.charConn then obj.charConn:Disconnect() end
        if obj.toolConn then obj.toolConn:Disconnect() end
        if obj.toolConn2 then obj.toolConn2:Disconnect() end
        
        -- Hide immediately then remove safely
        for _, arr in ipairs({obj.boxL, obj.boxO}) do
            if arr then 
                for _, d in ipairs(arr) do 
                    d.Visible = false
                    pcall(function() d:Remove() end) 
                end 
            end
        end
        
        for _, d in ipairs({obj.trOut, obj.tr, obj.nm, obj.dn, obj.dist, obj.tool, obj.hpBG, obj.hpBar, obj.hpTxt, obj.boxFill}) do
            d.Visible = false
            pcall(function() d:Remove() end)
        end
        
        objs[player] = nil
    end

    -- Temporarily hides all ESP elements for a player (e.g. when dead or out of view)
    local function hide(player)
        local obj = objs[player]
        if not obj then return end
        
        for _, arr in ipairs({obj.boxL, obj.boxO}) do
            if arr then 
                for _, d in ipairs(arr) do 
                    d.Visible = false 
