    -- Cleanup hook for unload
    -- BEAM TRACER system
    do
        local beams = {} -- active beam drawings {lines=[], born=tick()}
        local function isBeamVectorValid(v)
            if typeof(v) ~= "Vector3" then return false end
            return v.X == v.X and v.Y == v.Y and v.Z == v.Z
                and v.X ~= math.huge and v.X ~= -math.huge
                and v.Y ~= math.huge and v.Y ~= -math.huge
                and v.Z ~= math.huge and v.Z ~= -math.huge
        end
        local function spawnBeam(from3d, to3d)
            if not F("Visuals Beam") then return end
            if not isBeamVectorValid(from3d) or not isBeamVectorValid(to3d) then return end
            local segs   = math.floor(F("Visuals Beam Segments") or 8)
            local dur    = F("Visuals Beam Duration") or 1
            local width  = F("Visuals Beam Width") or 0.5
            local c1     = F("Visuals Beam Color")  or Color3.fromRGB(0,170,255)
            local c2     = F("Visuals Beam Color2") or Color3.fromRGB(255,0,255)
            if segs < 1 then segs = 1 end
            local lines  = {}
            for i = 1, segs do
                local ln = makeDrawing("Line")
                ln.Visible   = false
                ln.Thickness = width
                ln.Color     = c1:Lerp(c2, segs == 1 and 0 or ((i - 1) / (segs - 1)))
                ln.From      = Vector2.new(0, 0)
                ln.To        = Vector2.new(0, 0)
                ln.Transparency = 1
                lines[i]     = ln
            end
            beams[#beams+1] = {lines=lines, from=from3d, to=to3d, born=tick(), dur=dur}
        end

        -- hook bullet/projectile hits via RemoteEvent detection
        local RS2 = game:GetService("RunService")
        RS2.Heartbeat:Connect(function()
            local now = tick()
            local i = 1
            while i <= #beams do
                local b = beams[i]
                local age = now - b.born
                if age >= b.dur then
                    for _, ln in ipairs(b.lines) do ln:Remove() end
                    table.remove(beams, i)
                else
                    -- Optimized without Tween/Lerp calls
                    if typeof(b.from) ~= "Vector3" or typeof(b.to) ~= "Vector3" then
                        for _, ln in ipairs(b.lines) do pcall(function() ln:Remove() end) end
                        table.remove(beams, i)
                        continue
                    end
                    local fromSc = Cam:WorldToViewportPoint(b.from)
                    local toSc   = Cam:WorldToViewportPoint(b.to)
                    if fromSc.Z > 0 and toSc.Z > 0 then
                        local f2 = Vector2.new(fromSc.X, fromSc.Y)
                        local t2 = Vector2.new(toSc.X,   toSc.Y)
                        local alpha = 1 - (age / b.dur)
                        
                        for j = 1, #b.lines do
                            local t0 = (j-1)/#b.lines
                            local t1 = j/#b.lines
                            local p0 = f2 + (t2 - f2) * t0
                            local p1 = f2 + (t2 - f2) * t1
                            local ln = b.lines[j]
                            pcall(function()
                                ln.From = p0
                                ln.To = p1
                                ln.Transparency = alpha
                                ln.Visible = true
                            end)
                        end
                    else
                        for _, ln in ipairs(b.lines) do
                            pcall(function() ln.Visible = false end)
                        end
                    end
                    i = i + 1
                end
            end
        end)

        _G.VonkaBeamSpawn = spawnBeam
    end

    _G.VonkaESPCleanup = function()
        for p in pairs(objs) do rm(p) end
        fovOut:Remove(); fovIn:Remove(); fovFill:Remove()
        fovSqOut:Remove(); fovSqIn:Remove()
        for _,l in ipairs(fovTriOut) do l:Remove() end; for _,l in ipairs(fovTriIn)  do l:Remove() end
        for _,l in ipairs(fovDiaOut) do l:Remove() end; for _,l in ipairs(fovDiaIn)  do l:Remove() end
        for _,l in ipairs(fovCrsOut) do l:Remove() end; for _,l in ipairs(fovCrsIn)  do l:Remove() end
        labelGui:Destroy()
    end
    
    for _, p in ipairs(Players:GetPlayers()) do if p ~= LP then mk(p) end end
    Players.PlayerAdded:Connect(function(p) if p ~= LP then mk(p) end end)
    Players.PlayerRemoving:Connect(function(p)
        leaving[p] = true
        rm(p)
    end)

    -- Hit Sound Logic
    local SoundService = game:GetService("SoundService")
    local hitsounds = { 
        ["RIFK7"] = "rbxassetid://9102080552", 
        ["Bubble"] = "rbxassetid://9102092728", 
        ["Minecraft"] = "rbxassetid://5869422451", 
        ["Cod"] = "rbxassetid://160432334", 
        ["Bameware"] = "rbxassetid://6565367558", 
        ["Neverlose"] = "rbxassetid://6565370984", 
        ["Gamesense"] = "rbxassetid://4817809188", 
        ["Rust"] = "rbxassetid://6565371338" 
    }
    local HIT_GUN_TOOL_NAMES = {
        "[Revolver]", "[DoubleBarrel]", "[Double Barrel]", "[Shotgun]",
        "[Silencer]", "[TacticalShotgun]", "[Tactical Shotgun]", "[SMG]"
    }
    local HIT_GUN_KEYWORDS = {
        "shotgun", "revolver", "smg", "silencer", "doublebarrel", "double", "rifle"
    }
    local lastLocalShot = 0
    local shotWindow = 0.35

    local function isHoldingGun()
        local char = LP.Character
        if not char then return false end
        local tool = char:FindFirstChildOfClass("Tool")
        if not tool then return false end
        local rawName = tostring(tool.Name or "")
        local lowerName = string.lower(rawName)
        local compactName = lowerName:gsub("[%[%]%s%p_%-]", "")

        for _, name in ipairs(HIT_GUN_TOOL_NAMES) do
            if rawName == name then
                return true
            end
        end

        if tool:FindFirstChild("Ammo") or tool:FindFirstChild("GunScript") or tool:FindFirstChild("LocalScript") then
            return true
        end

        for _, kw in ipairs(HIT_GUN_KEYWORDS) do
            if lowerName:find(kw, 1, true) or compactName:find(kw, 1, true) then
                return true
            end
        end

        return false
    end

    UIS.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 and isHoldingGun() then
            lastLocalShot = tick()
            _G.VonkaLastLocalShot = lastLocalShot
        end
    end)

    local function playHitSound()
        if not F("Visuals Hit Sound") then return end
        local sType = F("Visuals Hit Sound Type") or "RIFK7"
        local sId = hitsounds[sType]
        if sId then
            local sound = Instance.new("Sound")
            sound.SoundId = sId
            sound.Volume = F("Visuals Hit Sound Volume") or 0.5
            sound.Name = "\0"
            sound.PlayOnRemove = true
            sound.Parent = SoundService
            sound:Destroy()
        end
    end

    local function trackHealth(char)
        local hum = char:WaitForChild("Humanoid", 5)
        if hum then
            local lastHealth = hum.Health
            local lastSoundTick = 0
            hum.HealthChanged:Connect(function(newHealth)
                if newHealth < lastHealth then
                    local now = tick()
                    local shotTick = math.max(lastLocalShot, _G.VonkaLastLocalShot or 0)
                    if (now - shotTick) <= shotWindow and (now - lastSoundTick) >= 0.045 then
                        lastSoundTick = now
                        playHitSound()
                    end
                end
                lastHealth = newHealth
            end)
        end
    end

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then
            if p.Character then trackHealth(p.Character) end
            p.CharacterAdded:Connect(trackHealth)
        end
    end
    Players.PlayerAdded:Connect(function(p)
        if p ~= LP then
            p.CharacterAdded:Connect(trackHealth)
        end
    end)
end

